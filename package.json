                         "nanoid":  "^5.1.7",
                         "react":  "^18.3.1",
                         "react-dom":  "^18.3.1",
                         "react-hook-form":  "^7.51.2",
                         "react-hot-toast":  "^2.6.0",
                         "react-router-dom":  "^6.22.3",
